# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
HTTP_LOG=1

# LLM (DeepSeek)
DEEPSEEK_API_KEY=your-deepseek-api-key

# Embeddings (OpenAI compatible)
OPENAI_API_KEY=your-openai-embedding-api-key
LOCAL_EMBED_URL=http://127.0.0.1:8123/embed/encode

# Python Gateway (Emotion Analysis / TTS)
PY_GATEWAY_URL=http://127.0.0.1:8123

# Weather (QWeather)
QWEATHER_API_KEY=your-qweather-api-key
QWEATHER_API_HOST=your-qweather-host

# Auth
ADMIN_SEED_KEY=your-admin-seed-key
SEED_USERNAME=admin

# Feature Flags
MESSAGE_FILTER_ENABLED=1
MESSAGE_FILTER_NLP_ENABLED=1
HARD_WRITE_NLP=0
INTENT_LLM_FALLBACK=0
